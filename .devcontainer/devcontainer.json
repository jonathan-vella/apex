{
  "name": "APEX",
  // Base image: mcr.microsoft.com/devcontainers/universal:2-linux. Includes Go,
  // Node (nvm), Python (pyenv), gh, Azure CLI, Git, Docker CLI, Java, Ruby, PHP,
  // .NET, Rust out of the box. Multi-arch (amd64 + arm64).
  //
  // We wrap it in a minimal Dockerfile that deletes a broken upstream apt
  // source (yarn.list w/ expired GPG key) which causes the terraform feature
  // install to fail. See .devcontainer/Dockerfile for details. When upstream
  // fixes this, replace the "build" block with:
  //   "image": "mcr.microsoft.com/devcontainers/universal:2-linux"
  "build": {
    "dockerfile": "Dockerfile"
  },

  "features": {
    // Universal ships a non-root 'codespace' user (uid 1000) with an apt
    // marker file that causes common-utils to fail on stale yarn GPG keys.
    // We intentionally do NOT add common-utils — all other features
    // auto-detect the existing 'codespace' user via _REMOTE_USER.
    "ghcr.io/devcontainers/features/azure-cli:1": {
      "installBicep": true,
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/powershell:1": {
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/terraform:1": {
      "tflint": "0.61.0",
      "installTFsec": false
    },
    "ghcr.io/devcontainers-community/features/deno": {
      "version": "latest"
    },
    "ghcr.io/azure/azure-dev/azd:latest": {}
  },

  // Lifecycle commands - chain apt operations to avoid lock conflicts
  // Lifecycle: onCreateCommand runs first (system packages + uv), then postCreateCommand (tools), then postStartCommand (updates)
  "onCreateCommand": "set -e; sudo apt-get update; sudo apt-get install -y graphviz dos2unix; sudo install -d -m 0755 -o codespace -g codespace \"$HOME/.cache\" \"$HOME/.local/bin\"; dos2unix .devcontainer/*.sh 2>/dev/null || true; curl -LsSf https://astral.sh/uv/install.sh | sh",
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "postStartCommand": "bash .devcontainer/post-start.sh && (npx lefthook install 2>/dev/null || true)",

  // Environment variables for Python optimization
  "containerEnv": {
    "PYTHONDONTWRITEBYTECODE": "1",
    "PYTHONUNBUFFERED": "1",
    "UV_CACHE_DIR": "/home/codespace/.cache/uv",
    "TF_PLUGIN_CACHE_DIR": "/home/codespace/.terraform.d/plugin-cache",
    "DENO_DIR": "/home/codespace/.cache/deno"
  },

  "remoteEnv": {
    "PATH": "${containerEnv:PATH}",
    "AZURE_DEFAULTS_LOCATION": "swedencentral",
    // Pass GH_TOKEN from host → container. gh CLI uses it automatically, no `gh auth login` needed.
    // Each user sets this once in VS Code User Settings (Ctrl+,):
    //   "terminal.integrated.env.linux": { "GH_TOKEN": "ghp_yourTokenHere" }
    // This is the ONLY supported method — shell exports (.bashrc/.profile) do NOT propagate reliably.
    // Value is empty string if not set — gh CLI falls back to its normal auth flow.
    "GH_TOKEN": "${localEnv:GH_TOKEN}"
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "GitHub.copilot-chat",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-vscode.vscode-node-azure-pack",
        "ms-azuretools.vscode-azureresourcegroups",
        "ms-azuretools.vscode-bicep",
        "ms-vscode.powershell",
        "bierner.markdown-mermaid",
        "bierner.markdown-preview-github-styles",
        "davidanson.vscode-markdownlint",
        "ms-vscode.azurecli",
        "ms-azuretools.vscode-azurecontainerapps",
        "ms-azuretools.vscode-azurestaticwebapps",
        "ms-azuretools.azure-dev",
        "ms-azuretools.vscode-containers",
        "ms-kubernetes-tools.vscode-kubernetes-tools",
        "ms-kubernetes-tools.vscode-aks-tools",
        "github.vscode-github-actions",
        "github.vscode-pull-request-github",
        "ms-azuretools.vscode-azure-mcp-server",
        "esbenp.prettier-vscode",
        "mechatroner.rainbow-csv",
        "redhat.vscode-yaml",
        "mutantdino.resourcemonitor",
        "HashiCorp.terraform",
        "ms-azuretools.vscode-azureterraform",
        "hediet.vscode-drawio",
        "denoland.vscode-deno"
      ],
      "settings": {
        "chat.customAgentInSubagent.enabled": true,
        "chat.agentFilesLocations": {
          ".github/agents": true,
          ".github/agents/_subagents": true
        },
        "chat.agentSkillsLocations": {
          ".github/skills": true
        },
        "chat.hookFilesLocations": {
          ".github/hooks/tool-guardian": true,
          ".github/hooks/secrets-scanner": true,
          ".github/hooks/session-logger": true,
          ".github/hooks/governance-audit": true,
          ".github/hooks/post-edit-format": true,
          ".github/hooks/subagent-validation": true
        },
        "chat.useCustomAgentHooks": true,
        "chat.useAgentSkills": true,
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.rulers": [120],
        "editor.wordWrap": "wordWrapColumn",
        "editor.wordWrapColumn": 120,
        "terminal.integrated.defaultProfile.linux": "bash",
        "files.eol": "\n",
        "editor.tabSize": 2,
        "[markdown]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode",
          "editor.rulers": [120],
          "editor.wordWrap": "wordWrapColumn",
          "editor.wordWrapColumn": 120
        },
        "[bicep]": {
          "editor.tabSize": 2
        },
        "[terraform]": {
          "editor.tabSize": 2,
          "editor.formatOnSave": true,
          "editor.defaultFormatter": "hashicorp.terraform"
        },
        "[powershell]": {
          "editor.tabSize": 4
        },
        "[python]": {
          "editor.tabSize": 4
        },
        // Python interpreter is pyenv-managed (pinned to 3.13 in post-create.sh).
        // Let Pylance auto-detect via pyenv shims instead of hard-coding a path.
        "python.analysis.typeCheckingMode": "basic",
        "markdownlint.config": {
          "extends": "${workspaceFolder}/.markdownlint-cli2.jsonc"
        },
        "markdownlint.run": "onSave",
        "deno.enable": false,
        "deno.enablePaths": ["mcp/drawio-mcp-server"],
        "deno.lint": true,
        "deno.unstable": []
      }
    }
  },

  // Mounts for credential/cache persistence across rebuilds
  // - Azure CLI: Host's ~/.azure (Linux/macOS) or %USERPROFILE%\.azure (Windows)
  // - GitHub CLI: Docker volume (Windows uses keyring, can't be mounted; Linux/macOS use files)
  // - UV cache: Docker volume for Python package cache
  "mounts": [
    {
      "source": "${localEnv:USERPROFILE}${localEnv:HOME}/.azure",
      "target": "/home/codespace/.azure",
      "type": "bind"
    },
    {
      "source": "devcontainer-gh-config-${devcontainerId}",
      "target": "/home/codespace/.config/gh",
      "type": "volume"
    },
    {
      "source": "devcontainer-uv-cache-${devcontainerId}",
      "target": "/home/codespace/.cache/uv",
      "type": "volume"
    }
  ],

  "remoteUser": "codespace"
}
