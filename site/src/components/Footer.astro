---
// Custom Footer for APEX docs
import DemoNavigationEnhancer from "./DemoNavigationEnhancer.astro";
import BackToTop from "./BackToTop.astro";

const gitSha = (import.meta.env.PUBLIC_GIT_SHA || "").slice(0, 7);
const buildDate = import.meta.env.PUBLIC_BUILD_DATE || "";
---

<DemoNavigationEnhancer />
<BackToTop />

<footer class="site-footer">
  <div class="footer-content">
    <p>
      <a href="https://github.com/jonathan-vella/apex" target="_blank" rel="noopener noreferrer">
        APEX
      </a>
      — Agentic Platform Engineering eXperience for Azure.
    </p>
    <p class="footer-meta">
      <a href="https://github.com/jonathan-vella/apex/blob/main/LICENSE" target="_blank" rel="noopener noreferrer">MIT License</a>
      <span class="footer-sep">·</span>
      <a href="https://github.com/jonathan-vella/apex-accelerator" target="_blank" rel="noopener noreferrer">Accelerator Template</a>
      <span class="footer-sep">·</span>
      <a href="/sitemap-index.xml">Sitemap</a>
      <span class="footer-sep">·</span>
      Built with <a href="https://starlight.astro.build/" target="_blank" rel="noopener noreferrer">Starlight</a>
    </p>
    {gitSha && (
      <p class="footer-revision">
        <span class="footer-rev-pill">
          Built from <code>{gitSha}</code>{buildDate && <> on {buildDate}</>}
        </span>
      </p>
    )}
  </div>
</footer>

<style>
  .site-footer {
    padding: 1.5rem var(--sl-content-pad-x);
    border-top: 1px solid var(--sl-color-hairline);
    font-size: 0.8rem;
    color: var(--sl-color-gray-3);
  }

  .footer-content {
    max-width: var(--sl-content-width);
    margin: 0 auto;
    text-align: center;
  }

  .footer-content p {
    margin: 0.25rem 0;
  }

  .footer-content a {
    color: var(--sl-color-gray-2);
    text-decoration: none;
    transition: color 0.15s;
  }

  .footer-content a:hover {
    color: var(--sl-color-accent);
  }

  .footer-meta {
    font-size: 0.75rem;
  }

  .footer-sep {
    margin: 0 0.4rem;
    color: var(--sl-color-gray-4);
  }

  .footer-revision {
    margin-top: 0.6rem !important;
    font-size: 0.7rem;
  }

  .footer-rev-pill {
    display: inline-block;
    padding: 0.15rem 0.55rem;
    border-radius: 999px;
    background: var(--sl-color-gray-6, rgba(120, 120, 120, 0.1));
    color: var(--sl-color-gray-3);
    border: 1px solid var(--sl-color-hairline);
  }

  .footer-rev-pill code {
    background: transparent;
    padding: 0;
    font-size: 0.7rem;
  }
</style>
